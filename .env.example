# URL do backend (ex: https://api.cristocentria.com.br)
BACKEND_URL=http://localhost:3001

# Auth.js v5 — obrigatório em produção (gere com: openssl rand -base64 32)
AUTH_SECRET=gere-com-openssl-rand-base64-32
AUTH_URL=https://seu-dominio.vercel.app

# Google OAuth — opcional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Segredo para chamadas internas — opcional
INTERNAL_API_SECRET=
